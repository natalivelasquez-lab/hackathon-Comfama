# Runtime
APP_ENV=local
LOG_LEVEL=INFO

# MVP local: coloca toda la data en esta carpeta.
APP_INPUT_MODE=local_layout
LOCAL_LAYOUT_ROOT_DIR=data/mvp_layout

# Reprocesamiento.
# Usa reprocess_all cuando quieras volver a generar y reenviar decisiones ya procesadas.
PROCESSING_POLICY=skip_unchanged
PROCESSING_STATE_FILENAME=processing_state.json

# Estructura de carpetas/archivos dentro de LOCAL_LAYOUT_ROOT_DIR
LAYOUT_CONFIG_DIR=00_Config
LAYOUT_REQUESTS_DIR=01_EntradaSolicitudes
LAYOUT_REPORTS_DIR=02_SalidaReportes
HISTORY_EXCEL_FILENAME=Historico_Auxilios.xlsx
BENEFITS_FILENAME=beneficios.csv

# MVP local: desactivado para evitar esperas de red.
AZURE_OPENAI_ENABLED=false
COSMOS_ENABLED=false

# Azure OpenAI opcional para una fase posterior
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_OMNIMODAL=gpt-5.1
AZURE_OPENAI_DEPLOYMENT_TEXT=gpt-5.1

# Cosmos DB opcional.
# Para guardar decisiones en Cosmos:
# 1. COSMOS_ENABLED=true
# 2. Completa COSMOS_ENDPOINT y COSMOS_KEY
# 3. Si las solicitudes ya fueron procesadas, usa PROCESSING_POLICY=reprocess_all
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=calidad_vida_auxilios
COSMOS_CONTAINER_REQUESTS=requests
COSMOS_CONTAINER_DOCUMENTS=documents
COSMOS_CONTAINER_DECISIONS=decisions
COSMOS_CONTAINER_EXECUTIONS=executions
